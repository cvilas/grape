#!/bin/bash
# =================================================================================================
# Copyright (C) 2025 GRAPE Contributors
# =================================================================================================
# Script to run Python test for grape_ipc_py in an isolated virtual environment.
# Requires uv (https://docs.astral.sh/uv/). Install via toolchains/install_base.sh.

WHEELS_DIR=@PY_WHEELS_DIR@
TEST_SCRIPT=@CMAKE_CURRENT_SOURCE_DIR@/host_raw_pub_sub_test.py
VENV_DIR="/tmp/grape_ipc_py_test_venv_$$"
TEST_RESULT=0

cleanup() {
    if [[ -d "${VENV_DIR}" ]]; then
        rm -rf "${VENV_DIR}"
    fi
    if [[ ${TEST_RESULT} -ne 0 ]]; then
        echo "Test failed with exit code ${TEST_RESULT}"
        exit ${TEST_RESULT}
    fi
    echo "Test passed."
}
trap cleanup EXIT

# Find the latest grape_ipc_py wheel
WHEEL_PATH=$(ls -t "${WHEELS_DIR}"/grape_ipc_py*.whl 2>/dev/null | head -n 1)
if [[ -z "${WHEEL_PATH}" ]]; then
    echo "ERROR: No grape_ipc_py wheel found in ${WHEELS_DIR}"
    TEST_RESULT=1
    exit 1
fi
echo "Found wheel: $(basename "${WHEEL_PATH}")"

# Create virtual environment and install wheel
@UV_EXECUTABLE@ venv --quiet "${VENV_DIR}"
@UV_EXECUTABLE@ pip install --quiet --python "${VENV_DIR}/bin/python" "${WHEEL_PATH}"

echo "Running test..."
"${VENV_DIR}/bin/python" "${TEST_SCRIPT}"
TEST_RESULT=$?
